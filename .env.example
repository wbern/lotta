# Copy this file to .env.local (gitignored) and fill in the values.
# .env.local is read by Vite and baked into the build; in CI these
# are supplied by the deploy workflow via GitHub repository secrets.

# metered.ca account API key used to fetch geo-nearest TURN credentials.
# Leave empty to skip the prefetch and fall back to openrelay's public tier.
VITE_METERED_API_KEY=
